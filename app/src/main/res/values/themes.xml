<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CountrySelection" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="MontserratRegular">
        <item name="android:fontFamily">@font/montserrat_thin</item>
        <item name="android:textFontWeight">300</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="MontserratMedium">
        <item name="android:fontFamily">@font/montserrat_thin</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="MontserratSemiBold">
        <item name="android:fontFamily">@font/montserrat_thin</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

</resources>